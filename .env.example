# FHIR R4B server base URL
# Default: local fhir-candle instance started with:
#   docker run --rm -p 8080:8080 ghcr.io/ginocanessa/fhir-candle:latest
# fhir-candle web UI (resource browser): http://localhost:8080
NEXT_PUBLIC_FHIR_BASE_URL=http://localhost:5826/fhir/r4b

# eMPI server base URL (falls back to FHIR base URL if not set)
# Can also be overridden at runtime from the Settings page
NEXT_PUBLIC_EMPI_BASE_URL=http://localhost:5826/fhir/r4b
